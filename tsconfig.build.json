{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "jsx": "react-jsx"
  },
  "include": [
    "src/core/**/*.ts",
    "src/core/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/core/**/*.test.ts",
    "src/core/**/*.test.tsx"
  ]
}
